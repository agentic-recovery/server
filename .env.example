# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://umair_admin:umair123@ac-qdm6dyr-shard-00-00.doli2qa.mongodb.net:27017,ac-qdm6dyr-shard-00-01.doli2qa.mongodb.net:27017,ac-qdm6dyr-shard-00-02.doli2qa.mongodb.net:27017/?ssl=true&replicaSet=atlas-si7odh-shard-0&authSource=admin&appName=agentic0
