JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# OpenAI — required for conversational chat feature
OPENAI_API_KEY=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
# Model to use for entity extraction and response generation (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Model to use for entity extraction and response generation (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Geocoding — no API key required (uses free Nominatim + postcodes.io)
# Optional: set your app name for Nominatim User-Agent header
GEOCODING_USER_AGENT=AIRecoverySystem/1.0

# Region bias for geocoding (default: UK — do not change unless deploying outside UK)
GEOCODING_COUNTRY_BIAS=gb

# Email (Nodemailer) — leave blank to auto-use Ethereal test account in dev
# Ethereal preview URLs will be logged to the console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=umairtariq.business@gmail.com
SMTP_PASS=umair@13747

EMAIL_FROM_NAME=AI Recovery
EMAIL_FROM_ADDRESS=no-reply@airecovery.co.uk


